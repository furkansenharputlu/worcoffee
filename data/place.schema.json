{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WorCoffee Place",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "country", "city", "address", "rating"],
  "properties": {
    "lang": { "type": "string", "pattern": "^[a-z]{2}(-[A-Z]{2})?$", "description": "Source language of the text fields. Default 'en'. Examples: 'en', 'tr', 'de'." },
    "name": { "type": "string", "minLength": 1, "description": "Place name in the source language." },
    "name_i18n": { "type": "object", "additionalProperties": { "type": "string" }, "description": "Translations of name keyed by language code." },
    "country": { "type": "string", "minLength": 2, "description": "Country in the source language. Group identity comes from the folder path." },
    "country_i18n": { "type": "object", "additionalProperties": { "type": "string" } },
    "city": { "type": "string", "minLength": 1 },
    "city_i18n": { "type": "object", "additionalProperties": { "type": "string" } },
    "address": { "type": "string", "minLength": 1 },
    "address_i18n": { "type": "object", "additionalProperties": { "type": "string" } },
    "description": { "type": "string" },
    "description_i18n": { "type": "object", "additionalProperties": { "type": "string" } },
    "type": {
      "type": "string",
      "enum": ["cafe", "coworking", "library", "hotel-lobby", "restaurant", "other"]
    },
    "rating": {
      "type": "object",
      "additionalProperties": false,
      "required": ["wifi", "power", "noise", "comfort"],
      "properties": {
        "wifi":    { "type": "integer", "minimum": 1, "maximum": 5 },
        "power":   { "type": "integer", "minimum": 1, "maximum": 5 },
        "noise":   { "type": "integer", "minimum": 1, "maximum": 5, "description": "1=loud, 5=quiet" },
        "comfort": { "type": "integer", "minimum": 1, "maximum": 5 }
      }
    },
    "hours": { "type": "string" },
    "price": { "type": "string", "enum": ["$", "$$", "$$$", "$$$$"] },
    "tags":  { "type": "array", "items": { "type": "string" } },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "google_maps": { "type": "string", "format": "uri" },
        "instagram":   { "type": "string", "format": "uri" },
        "website":     { "type": "string", "format": "uri" },
        "menu":        { "type": "string", "format": "uri" }
      }
    },
    "coords": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lat", "lng"],
      "properties": {
        "lat": { "type": "number", "minimum": -90,  "maximum": 90 },
        "lng": { "type": "number", "minimum": -180, "maximum": 180 }
      }
    },
    "submitted_by": { "type": "string" }
  }
}
